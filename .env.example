# Runtime
POKEBUY_ENV=dev
POKEBUY_DATA_DIR=.pokebuy
POKEBUY_BROWSER_STATE_DIR=.pokebuy/browser-state
POKEBUY_BROWSER_PROFILE_DIR=.pokebuy/browser-profile
POKEBUY_DATABASE_URL=sqlite:///.pokebuy/pokebuy.sqlite3
POKEBUY_SECRET_KEY=change-me-for-local-development

# Polling
POKEBUY_POLL_MIN_SECONDS=30
POKEBUY_HTTP_TIMEOUT_SECONDS=20
POKEBUY_HTTP_MAX_ATTEMPTS=2
POKEBUY_HTTP_RETRY_BACKOFF_SECONDS=1
POKEBUY_HTTP_RETRY_AFTER_MAX_SECONDS=60
POKEBUY_BROWSER_TIMEOUT_SECONDS=45
POKEBUY_BROWSER_MANUAL_WAIT_SECONDS=0
POKEBUY_BROWSER_HEADLESS=false
POKEBUY_WEB_HOST=127.0.0.1
POKEBUY_WEB_PORT=8000

# Logging
POKEBUY_LOG_FILE_ENABLED=true
POKEBUY_LOG_FILE_PATH=pokebuy.log

# Debugging
POKEBUY_DEBUG_ENABLED=true
POKEBUY_DEBUG_PRINT_HTML=true
POKEBUY_DEBUG_REDACT_HTML=false
POKEBUY_DEBUG_DIR=debug

# Notifications
POKEBUY_DISCORD_WEBHOOK_URL=
POKEBUY_SMTP_HOST=
POKEBUY_SMTP_PORT=587
POKEBUY_SMTP_USERNAME=
POKEBUY_SMTP_PASSWORD=
POKEBUY_EMAIL_FROM=
POKEBUY_EMAIL_TO=

# Automation feature flags
POKEBUY_AUTO_CART_ENABLED=false
POKEBUY_AUTO_CHECKOUT_ENABLED=false
