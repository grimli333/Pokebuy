# Runtime
POKEBUY_ENV=dev
POKEBUY_DATA_DIR=.pokebuy
POKEBUY_BROWSER_STATE_DIR=.pokebuy/browser-state
POKEBUY_DATABASE_URL=sqlite:///.pokebuy/pokebuy.sqlite3
POKEBUY_SECRET_KEY=change-me-for-local-development

# Polling
POKEBUY_POLL_MIN_SECONDS=30
POKEBUY_HTTP_TIMEOUT_SECONDS=20

# Notifications
POKEBUY_DISCORD_WEBHOOK_URL=
POKEBUY_SMTP_HOST=
POKEBUY_SMTP_PORT=587
POKEBUY_SMTP_USERNAME=
POKEBUY_SMTP_PASSWORD=
POKEBUY_EMAIL_FROM=
POKEBUY_EMAIL_TO=

# Automation feature flags
POKEBUY_AUTO_CART_ENABLED=false
POKEBUY_AUTO_CHECKOUT_ENABLED=false
